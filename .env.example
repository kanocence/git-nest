# ========================================
# Git Nest — 环境变量配置
# ========================================
# 复制此文件为 .env 并修改值：
#   cp .env.example .env
# ========================================

# --- 用户映射 ---
# Server 上 git 用户的 UID/GID，确保 git-runner、agent、code-server 以同一身份访问数据目录
PUID=1000
PGID=1000

# --- 安全 ---
# git-runner 与 nuxt-app 之间的共享密钥（必须修改！）
# 生成建议：openssl rand -hex 32
GIT_RUNNER_SECRET=change-me-to-a-random-string
# agent 与 nuxt-app 之间的共享密钥（必须修改！）
AGENT_SECRET=change-me-to-another-random-string

# Web 界面登录密码（留空则不启用密码保护）
WEB_PASSWORD=

# --- 数据目录（宿主机路径）---
# Bare 仓库存储目录
GIT_DATA_DIR=./data/git
# 工作区目录（clone 后的目录）
GIT_WORKSPACE_DIR=./data/workspace
# Agent 状态目录（SQLite/运行记录）
AGENT_STATE_DIR=./data/agent-state

# --- AI 执行器 ---
# Git Nest Agent 仅支持 Goose CLI 作为 coding executor（需要安装 goose）
AGENT_EXECUTOR_MAX_TURNS=30
AGENT_EXECUTOR_TIMEOUT_MS=1800000

# --- Goose 执行器配置 ---
# Goose provider: openai, anthropic, google, azure_openai, ollama 等
# Agent 透传此环境变量给 Goose CLI
GOOSE_PROVIDER=openai
# Goose 模型名称
GOOSE_MODEL=gpt-4o-mini

# AI Provider API Keys（根据 GOOSE_PROVIDER 设置对应 key）
# OpenAI / Kimi / MiniMax / 其他 OpenAI 兼容服务
OPENAI_API_KEY=
OPENAI_BASE_URL=              # 可选，自定义 OpenAI 兼容端点，如 https://api.moonshot.cn/v1

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_HOST=               # 可选，默认 https://api.anthropic.com

# Google Gemini
GOOGLE_API_KEY=

# Azure OpenAI（如使用 azure_openai provider）
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT_NAME=
# AZURE_OPENAI_API_KEY=

# Git 提交信息
AGENT_GIT_USER_NAME=Git Nest AI
AGENT_GIT_USER_EMAIL=ai@git-nest.local

# --- 旧版配置（已弃用，保留兼容）---
COMMAND_TIMEOUT_MS=120000

# --- Webhook 通知 ---
# Webhook 接收 URL（计划功能：当前仅校验配置，不发送 webhook）
WEBHOOK_URL=
# Webhook 签名密钥（用于 HMAC-SHA256 签名验证）
WEBHOOK_SECRET=
# Webhook 请求超时（毫秒，默认 30000 = 30秒）
WEBHOOK_TIMEOUT_MS=30000
# Webhook 最大重试次数（默认 3 次）
WEBHOOK_MAX_RETRIES=3

# --- 端口 ---
# Web 界面对外暴露端口
WEB_PORT=3000

# --- 使用预构建镜像 ---
# tag 可使用 latest、main、版本号或 commit sha。
GIT_NEST_WEB_IMAGE=ghcr.io/kanocence/git-nest-web:latest
GIT_NEST_RUNNER_IMAGE=ghcr.io/kanocence/git-nest-runner:latest
GIT_NEST_AGENT_IMAGE=ghcr.io/kanocence/git-nest-agent:latest
GIT_NEST_CODE_SERVER_IMAGE=ghcr.io/kanocence/git-nest-code-server:latest

# --- Web → Agent 连接配置（本地开发时使用）---
# 在 docker-compose 中这些值已自动内联，本地开发时请指向实际 Agent 地址
NUXT_AGENT_HOST=localhost
NUXT_AGENT_PORT=3002
NUXT_AGENT_SECRET=${AGENT_SECRET}

# --- Server 主机 ---
# Web 界面的域名或 IP（用于页面标识，通常与浏览器地址一致）
# 示例: 192.168.1.100 或 git-nest.your-domain.com
NUXT_PUBLIC_SERVER_HOST=

# --- SSH 访问 ---
# SSH 服务的主机名或 IP（用于 SSH Clone URL 显示）
# 如果与 SERVER_HOST 不同（例如 SSH 走独立域名/IP），请单独配置
# 留空则自动使用 SERVER_HOST 的值
# 示例: git.your-domain.com 或 192.168.1.100
SSH_HOST=
# SSH 端口（用于 SSH Clone URL 中的端口显示）
SSH_PORT=22
# 宿主机上 bare 仓库的绝对路径（SSH Clone URL 中的路径部分）
# 必须与 GIT_DATA_DIR 指向宿主机上相同的目录
# 示例: /data/git 或 /volume1/git-repos
SSH_GIT_PATH=/opt/git-nest/data/git

# --- 备份 ---
# 备份存储目录
BACKUP_DIR=./data/backups
# 备份保留天数（超过此天数的旧备份自动清理）
BACKUP_RETENTION_DAYS=7
# 定时备份执行小时（0-23，默认凌晨3点）
BACKUP_SCHEDULE_HOUR=3

# --- code-server（在线编辑器）---
# code-server 对外暴露端口
CODE_SERVER_PORT=8443
# code-server 完整 URL（前端“Open in Editor”按钮跳转地址）
# 示例: http://nas-ip:8443 或 https://code.your-domain.com
CODE_SERVER_URL=
# code-server 登录密码（留空则无密码保护）
CODE_SERVER_PASSWORD=
# code-server sudo 密码（可选）
# CODE_SERVER_SUDO_PASSWORD=

# --- 可选配置 ---
# git 命令执行超时（秒），默认 30
# COMMAND_TIMEOUT=30
# 时区
# TZ=Asia/Shanghai
