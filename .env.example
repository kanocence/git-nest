# ========================================
# Git Nest — 环境变量配置
# ========================================
# 复制此文件为 .env 并修改值：
#   cp .env.example .env
#   sh scripts/init-host.sh
# ========================================

# --- 用户映射 ---
# Server 上 git 用户的 UID/GID，确保 git-runner、agent、code-server 以同一身份访问数据目录
# DOCKER_GID 是宿主机 docker 组的 GID，agent 需要加入该组才能操作 Docker socket
# 获取方式：getent group docker | cut -d: -f3
PUID=1000
PGID=1000
DOCKER_GID=999

# --- 安全 ---
# git-runner 与 nuxt-app 之间的共享密钥（必须修改！）
# 生成建议：openssl rand -hex 32
GIT_RUNNER_SECRET=change-me-to-a-random-string

# Web 界面登录密码（留空则不启用密码保护）
WEB_PASSWORD=

# --- 数据目录（宿主机路径）---
# Bare 仓库存储目录
GIT_DATA_DIR=./data/git
# 工作区目录
GIT_WORKSPACE_DIR=./data/workspace
# Agent 状态目录
AGENT_STATE_DIR=./data/agent-state

# --- Hermes 数据目录（宿主机路径）---
HERMES_DATA_DIR=./data/hermes

# --- AI 执行器 ---
AGENT_EXECUTOR_MAX_TURNS=30
AGENT_EXECUTOR_TIMEOUT_MS=1800000
# Executor timeout 后进入 waiting_continuation，最多允许继续几次
AGENT_EXECUTOR_MAX_CONTINUATIONS=2

# --- Hermes 执行器配置 ---
# Hermes Docker 镜像
HERMES_IMAGE=nousresearch/hermes-agent:latest
# Hermes toolsets: file,terminal。可选追加 web
HERMES_TOOLSETS=file,terminal
# Hermes provider 和 model。留空则使用 Hermes config.yaml 默认配置
HERMES_PROVIDER=
HERMES_MODEL=

# Docker 宿主机绝对路径。agent 通过 bind mount 挂载，需使用绝对路径
# 支持相对路径，scripts/init-host.sh 会自动解析为绝对路径并更新 .env
# 默认与 GIT_WORKSPACE_DIR / AGENT_STATE_DIR / HERMES_DATA_DIR 保持一致
# 留空则使用默认值
HERMES_HOST_WORKSPACE_DIR=
HERMES_HOST_AGENT_STATE_DIR=
HERMES_HOST_DATA_DIR=

# AI Provider API Keys（根据 HERMES_PROVIDER 设置对应 key）
# OpenRouter
OPENROUTER_API_KEY=
# Anthropic
ANTHROPIC_API_KEY=
# Kimi
KIMI_API_KEY=
KIMI_CN_API_KEY=
# MiniMax
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
# Alibaba (DashScope)
DASHSCOPE_API_KEY=
# Google
GOOGLE_API_KEY=
# Gemini
GEMINI_API_KEY=
# DeepSeek
DEEPSEEK_API_KEY=
# Arcee AI
ARCEEAI_API_KEY=
# Xiaomi
XIAOMI_API_KEY=
# Hugging Face
HF_TOKEN=
# xAI / Grok
XAI_API_KEY=
# GLM / ZAI
GLM_API_KEY=

# Git 提交信息
AGENT_GIT_USER_NAME=Git Nest AI
AGENT_GIT_USER_EMAIL=ai@git-nest.local

# 普通命令超时，毫秒。默认 120000 = 2 分钟
COMMAND_TIMEOUT_MS=120000

# --- Webhook 通知 ---
# Webhook 接收 URL。计划功能：当前仅校验配置，不发送
WEBHOOK_URL=
# Webhook 签名密钥。用于 HMAC-SHA256 签名验证
WEBHOOK_SECRET=
# Webhook 请求超时，毫秒。默认 30000 = 30 秒
WEBHOOK_TIMEOUT_MS=30000
# Webhook 最大重试次数。默认 3 次
WEBHOOK_MAX_RETRIES=3

# --- 端口 ---
# Web 界面对外暴露端口
WEB_PORT=3000

# --- 使用预构建镜像 ---
# tag 可使用 latest、main、版本号或 commit sha。
GIT_NEST_WEB_IMAGE=ghcr.io/kanocence/git-nest-web:latest
GIT_NEST_RUNNER_IMAGE=ghcr.io/kanocence/git-nest-runner:latest
GIT_NEST_CODE_SERVER_IMAGE=ghcr.io/kanocence/git-nest-code-server:latest

# --- Server 主机 ---
# Web 界面的域名或 IP。用于页面标识，通常与浏览器地址一致
# 示例: 192.168.1.100 或 git-nest.your-domain.com
NUXT_PUBLIC_SERVER_HOST=

# --- SSH 访问 ---
# SSH 服务的主机名或 IP。用于 SSH Clone URL 显示
# 如果与 SERVER_HOST 不同，例如 SSH 走独立域名/IP，请单独配置
# 留空则自动使用 SERVER_HOST 的值
# 示例: git.your-domain.com 或 192.168.1.100
SSH_HOST=
# SSH 端口。用于 SSH Clone URL 中的端口显示
SSH_PORT=22
# SSH Clone URL 中的路径部分。默认与 GIT_DATA_DIR 保持一致
# 如果 SSH 服务需要宿主机绝对路径，请改为 /data/git 或 /volume1/git-repos
SSH_GIT_PATH=./data/git

# --- 备份 ---
# 备份存储目录
BACKUP_DIR=./data/backups
# 备份保留天数。超过此天数的旧备份自动清理
BACKUP_RETENTION_DAYS=7
# 定时备份执行小时。0-23，默认凌晨 3 点
BACKUP_SCHEDULE_HOUR=3

# --- code-server 在线编辑器 ---
# code-server 对外暴露端口
CODE_SERVER_PORT=8443
# code-server 完整 URL。前端 "Open in Editor" 按钮跳转地址
# 示例: http://nas-ip:8443 或 https://code.your-domain.com
CODE_SERVER_URL=
# code-server 登录密码。留空则无密码保护
CODE_SERVER_PASSWORD=
# code-server sudo 密码。可选
# CODE_SERVER_SUDO_PASSWORD=

# Advanced: custom code-server build directory.
# Enable only via: sh scripts/init-host.sh --custom-code-server
# CODE_SERVER_CUSTOM_DIR is user-facing and may use "~".
# CODE_SERVER_BUILD_CONTEXT is written by init-host.sh as an absolute path for Docker Compose.
CODE_SERVER_CUSTOM_DIR=
CODE_SERVER_BUILD_CONTEXT=

# --- 可选配置 ---
# git 命令执行超时（秒），默认 30
# COMMAND_TIMEOUT=30
# 时区
# TZ=Asia/Shanghai
