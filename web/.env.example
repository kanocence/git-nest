# ──────────────────────────────────────────────────────────────────────────────
# Git Nest — Web Environment Variables
# Copy this file to .env and fill in values as needed.
# ──────────────────────────────────────────────────────────────────────────────

# ── Mock mode ──────────────────────────────────────────────────────────────────
# Set to "true" to enable mock GET endpoints (no Docker / runner required).
# Only query/display APIs are intercepted; mutation APIs return 503 normally.
# NEVER enable in production.
# MOCK=true

# ── Auth ───────────────────────────────────────────────────────────────────────
# Leave empty to disable password protection (open access).
# WEB_PASSWORD=changeme

# ── Git runner ─────────────────────────────────────────────────────────────────
# GIT_RUNNER_HOST=localhost
# GIT_RUNNER_PORT=3001
# GIT_RUNNER_SECRET=dev-secret

# ── Agent runtime ──────────────────────────────────────────────────────────────
# GIT_DATA_DIR=/data/git
# GIT_WORKSPACE_DIR=/data/workspace
# AGENT_STATE_DIR=/tmp/git-nest-agent-state

# ── Hermes executor ────────────────────────────────────────────────────────────
# HERMES_IMAGE=nousresearch/hermes-agent:latest
# HERMES_HOST_WORKSPACE_DIR=/data/workspace
# HERMES_HOST_AGENT_STATE_DIR=/tmp/git-nest-agent-state
# HERMES_HOST_DATA_DIR=/data/git
